<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team.lms.mapper.CategoryMapper">

    <resultMap id="CategoryResultMap" type="com.team.lms.entity.Category">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="name" column="name"/>
        <result property="enabled" column="enabled"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <select id="selectById" resultMap="CategoryResultMap">
        select * from categories where id = #{id} and deleted = false
    </select>

    <select id="selectAllActive" resultMap="CategoryResultMap">
        select * from categories where deleted = false and enabled = true order by id asc
    </select>

    <insert id="insert" parameterType="com.team.lms.entity.Category" useGeneratedKeys="true" keyProperty="id">
        insert into categories(code, name, enabled, created_at, updated_at, deleted)
        values(#{code}, #{name}, #{enabled}, now(), now(), false)
    </insert>

    <update id="update" parameterType="com.team.lms.entity.Category">
        update categories
        set code = #{code},
            name = #{name},
            enabled = #{enabled},
            updated_at = now()
        where id = #{id}
    </update>
</mapper>
